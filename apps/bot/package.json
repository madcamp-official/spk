{
  "name": "@life-reroll/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Life Reroll Discord 봇 — 독립 장기 실행 프로세스 (DiscordBot.md §A.1)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsc -p tsconfig.json && node --env-file-if-exists=.env dist/index.js",
    "migrate": "tsc -p tsconfig.json && node --env-file-if-exists=.env dist/db/migrate.js",
    "sync-commands": "tsc -p tsconfig.json && node --env-file-if-exists=.env dist/deploy-commands.js",
    "verify": "tsc -p tsconfig.json && node --env-file-if-exists=.env dist/verify.js"
  },
  "dependencies": {
    "@life-reroll/core": "workspace:*",
    "discord.js": "^14.16.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "typescript": "^5.9.3"
  }
}
