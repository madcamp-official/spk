# apps/bot 환경변수. 이 파일을 .env 로 복사해서 채운다.
# ⚠ .env 는 절대 커밋하지 않는다(.gitignore에 있음). 토큰이 레포에 들어가면 즉시 재발급해야 한다.

# ── Discord ────────────────────────────────────────────────
# https://discord.com/developers/applications 에서 발급
DISCORD_TOKEN=
DISCORD_APP_ID=
# 개발 중 커맨드 sync는 길드 스코프로 한다(§A.7) — 전역 등록은 반영에 최대 1시간 걸린다.
# 비워 두면 전역 등록이 되므로, 개발 중에는 반드시 채울 것.
DEV_GUILD_ID=

# ── DB (§A.4 모든 상태는 DB) ───────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/lifereroll
# Supabase 등 관리형은 TLS가 필요하다. 자체 서명 인증서면 no-verify 로.
PGSSLMODE=

# "1일 3회"의 하루 경계를 판정할 시간대. Postgres 시간대 이름.
ROLL_DAY_TZ=Asia/Seoul

# ── LLM 인생 요약 (§F, 선택) ────────────────────────────────
# 비워 두면 템플릿만 쓴다 — 봇은 정상 동작한다. OpenAI 호환 API면 무엇이든 된다(vLLM 포함).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# 이 값보다 희귀한 생(상위 %)에만 실시간 LLM을 부른다. §F "레어 생에만".
LLM_RARITY_TOP_PCT=0.1
# 응답이 늦으면 템플릿으로 넘어간다. defer는 15분이지만 사람이 기다리는 한계는 훨씬 짧다.
LLM_TIMEOUT_MS=8000
